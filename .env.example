# ⚠️ ВАЖНО: Этот файл является ШАБЛОНОМ и не содержит реальных ключей!
# ⚠️ Скопируйте его в .env и заполните своими значениями
# ⚠️ Файл .env НЕ ДОЛЖЕН попадать в систему контроля версий (git ignore)

# ════════════════════════════════════════════════════════════════
# 🔐 БЕЗОПАСНОСТЬ: Перед использованием прочитайте SECURITY.md
# ════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════
# 🔴 РЕКОМЕНДАЦИИ ПО БЕЗОПАСНОСТИ:
# 1. Никогда не коммитьте .env в Git
# 2. Регулярно ротируйте ключи (каждые 90 дней)
# 3. Используйте секрет-менеджер для production (Vault, AWS Secrets Manager)
# 4. Ограничьте права API ключей минимально необходимыми
# 5. Включите мониторинг использования ключей
# ════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════
# Telegram Bot
# ════════════════════════════════════════════════════════════════
# Получите токен у @BotFather в Telegram
# ⚠️ Храните токен в секрете — он дает полный доступ к боту
# ⚠️ При компрометации немедленно создайте нового бота
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ════════════════════════════════════════════════════════════════
# AI Provider выбор (openai, gigachat или proxyapi)
# ════════════════════════════════════════════════════════════════
AI_PROVIDER=proxyapi

# ════════════════════════════════════════════════════════════════
# OpenAI (обязателен только при AI_PROVIDER=openai)
# ════════════════════════════════════════════════════════════════
# ⚠️ Ключ начинается с "sk-" — храните в секрете
# ⚠️ Эмбеддинги для RAG создаются локально (sentence-transformers)
# ⚠️ OPENAI_API_KEY не обязателен при использовании GigaChat/ProxyAPI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1000

# ════════════════════════════════════════════════════════════════
# GigaChat
# ════════════════════════════════════════════════════════════════
# ⚠️ Authorization key в формате Basic <key>
# ⚠️ Получите в консоли GigaChat: https://gigachat.devices.sberbank.ru/
# ⚠️ SSL верификация включена по умолчанию (verify_ssl=True)
GIGACHAT_AUTHORIZATION_KEY=your_gigachat_authorization_key_here
GIGACHAT_MODEL=GigaChat
GIGACHAT_TEMPERATURE=0.7
GIGACHAT_MAX_TOKENS=1000

# ════════════════════════════════════════════════════════════════
# ProxyAPI
# ════════════════════════════════════════════════════════════════
# ⚠️ API ключ для ProxyAPI (получить на https://console.proxyapi.ru/keys)
# ⚠️ ⚠️ Ключ можно увидеть полностью ТОЛЬКО ОДИН РАЗ при создании!
# ⚠️ ⚠️ Сохраните его надежно — восстановить невозможно!
# ⚠️ Ключ начинается с "sk-" — храните в секрете
PROXYAPI_API_KEY=your_proxyapi_api_key_here
PROXYAPI_MODEL=gpt-4o-mini
PROXYAPI_TEMPERATURE=0.7
PROXYAPI_MAX_TOKENS=1000
PROXYAPI_BASE_URL=https://api.proxyapi.ru
# Опционально: URL прокси для ProxyAPI (для корпоративных сетей)
# PROXYAPI_PROXY_URL=http://proxy.example.com:8080

# ════════════════════════════════════════════════════════════════
# ChromaDB (векторная база данных)
# ════════════════════════════════════════════════════════════════
# ⚠️ Директория содержит чувствительные данные — защитите доступ
# ⚠️ Рекомендуется шифрование диска для production
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=documents

# ════════════════════════════════════════════════════════════════
# RAG параметры
# ════════════════════════════════════════════════════════════════
RAG_N_RESULTS=5
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# ════════════════════════════════════════════════════════════════
# Session настройки
# ════════════════════════════════════════════════════════════════
SESSION_TIMEOUT=3600
MAX_CONTEXT_MESSAGES=10
