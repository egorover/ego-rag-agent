# Telegram Bot
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Provider (openai, gigachat или proxyapi)
AI_PROVIDER=proxyapi

# OpenAI
# API ключ для OpenAI (нужен даже при использовании GigaChat для embeddings)
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1000

# GigaChat
# Authorization key в формате Basic <key>
GIGACHAT_AUTHORIZATION_KEY=your_gigachat_authorization_key_here
GIGACHAT_MODEL=GigaChat
GIGACHAT_TEMPERATURE=0.7
GIGACHAT_MAX_TOKENS=1000

# ProxyAPI
# API ключ для ProxyAPI (получить на https://console.proxyapi.ru/keys)
# ⚠️ Ключ можно увидеть полностью только один раз при создании!
PROXYAPI_API_KEY=your_proxyapi_api_key_here
PROXYAPI_MODEL=gpt-4o-mini
PROXYAPI_TEMPERATURE=0.7
PROXYAPI_MAX_TOKENS=1000
PROXYAPI_BASE_URL=https://api.proxyapi.ru
# Опционально: URL прокси для ProxyAPI
# PROXYAPI_PROXY_URL=http://proxy.example.com:8080

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=documents

# RAG
RAG_N_RESULTS=5
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Session
SESSION_TIMEOUT=3600
MAX_CONTEXT_MESSAGES=10
