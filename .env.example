# Telegram Bot
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Provider (openai или gigachat)
AI_PROVIDER=gigachat

# OpenAI
# API ключ для OpenAI (нужен даже при использовании GigaChat для embeddings)
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1000

# GigaChat
# Authorization key в формате Basic <key>
GIGACHAT_AUTHORIZATION_KEY=your_gigachat_authorization_key_here
GIGACHAT_MODEL=GigaChat
GIGACHAT_TEMPERATURE=0.7
GIGACHAT_MAX_TOKENS=1000

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=documents

# RAG
RAG_N_RESULTS=5
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Session
SESSION_TIMEOUT=3600
MAX_CONTEXT_MESSAGES=10
